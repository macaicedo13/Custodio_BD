# =============================================================================
# PLANTILLA DE CONFIGURACION - caducidad_bds
# Copiar este archivo como .env y completar los valores reales.
# NUNCA versionar el archivo .env con valores reales.
# Aplicar permisos restringidos: chmod 600 .env
# =============================================================================

# --- Servidor de sanitizacion (DBSANETIZACION) ---
# Aqui viven las tablas INVENTARIO_BASES, HISTORIAL_BASES, instancias
SAN_HOST=localhost
SAN_PORT=55432
SAN_DATABASE=dbdba
SAN_USER=sa
SAN_PASSWORD=SqlServer2026!Lab


# --- Credencial unica para todas las instancias destino ---
# Mismo usuario con las mismas credenciales en DEV, QA y PROVEEDORES
DEST_USER=svc_caducidad
DEST_PASSWORD=SvcCaducidad2026!Lab

# --- Configuracion del script ---
# Timeout de conexion en segundos por instancia destino
CONN_TIMEOUT=30

# Dias de retencion de archivos de log
LOG_RETENTION_DAYS=90

# Directorio de logs (relativo al script o absoluto)
LOG_DIR=logs
